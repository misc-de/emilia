# Rust-Build-Artefakte
/target

# Flatpak: lokale Build-Verzeichnisse und das gehostete OSTree-Repo
/.flatpak-builder
/.flatpak-build
/build-dir
/repo
/repo-*
/*.flatpak

# Flathub-Hilfswerkzeuge (Generator-Skript + venv); generated-sources.json wird
